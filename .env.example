# ─────────────────────────────────────────────
#  SHOWPASS — Environment Variables
#  Copy this file to .env and fill in values
# ─────────────────────────────────────────────

# ── Database (Neon.tech — free tier) ──────────
# Sign up at https://neon.tech
DATABASE_URL="postgresql://USER:PASSWORD@HOST/showpass?sslmode=require"

# ── Auth (NextAuth v5) ────────────────────────
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET="your-super-secret-32-char-minimum-key-here"
NEXTAUTH_URL="http://localhost:3000"

# Google OAuth (console.cloud.google.com)
# Create OAuth 2.0 credentials → Web App
# Redirect URI: http://localhost:3000/api/auth/callback/google
GOOGLE_CLIENT_ID="your-google-client-id.apps.googleusercontent.com"
GOOGLE_CLIENT_SECRET="your-google-client-secret"

# ── Cloudinary (free: 25GB) ───────────────────
# Sign up at https://cloudinary.com
CLOUDINARY_CLOUD_NAME="your-cloud-name"
CLOUDINARY_API_KEY="your-api-key"
CLOUDINARY_API_SECRET="your-api-secret"

# ── Razorpay Sandbox ──────────────────────────
# Sign up at https://razorpay.com → Test Mode
RAZORPAY_KEY_ID="rzp_test_xxxxxxxxxxxx"
RAZORPAY_KEY_SECRET="your-razorpay-key-secret"
# Also needed client-side:
NEXT_PUBLIC_RAZORPAY_KEY_ID="rzp_test_xxxxxxxxxxxx"

# ── Email — Resend (free: 3,000/month) ────────
# Sign up at https://resend.com
RESEND_API_KEY="re_xxxxxxxxxxxxxxxxxxxx"
RESEND_FROM_EMAIL="tickets@showpass.live"

# ── AI APIs (all free tier) ───────────────────
# Google Gemini: https://aistudio.google.com
# Free: 1,500 req/day, 15 RPM
GEMINI_API_KEY="AIza..."

# Groq: https://console.groq.com
# Free: 14,400 req/day, 30 RPM
GROQ_API_KEY="gsk_..."

# OpenRouter: https://openrouter.ai
# Free models available
OPENROUTER_API_KEY="sk-or-..."

# ── QR Code Signing ───────────────────────────
# Any random string — used to sign ticket JWTs
QR_SECRET="showpass-qr-signing-secret-change-this-in-production"

# ── App URL ───────────────────────────────────
NEXT_PUBLIC_APP_URL="http://localhost:3000"
